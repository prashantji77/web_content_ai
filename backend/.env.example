OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=AI Web Content Summarizer
# Use a valid OpenRouter model id. Free models end in ":free".
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# Optional: use OpenAI-compatible embeddings instead of local hashing embeddings.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDINGS_PROVIDER=local

REQUEST_TIMEOUT_SECONDS=20
LLM_TIMEOUT_SECONDS=60
MAX_PROMPT_CHARS=18000
MAX_PAGES_PER_REQUEST=8
MIN_CONTENT_LENGTH=120
CORS_ORIGINS=*
FAISS_STORAGE_DIR=storage/faiss
PERSIST_FAISS=true

# Semantic search tuning
CHUNK_SIZE=800
CHUNK_OVERLAP=160
RETRIEVER_K=6
RETRIEVER_FETCH_K=20
RETRIEVER_SEARCH_TYPE=mmr

